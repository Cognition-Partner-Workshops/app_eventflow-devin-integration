{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderCreated Event",
  "description": "Event published by the Order Service when a new order is created",
  "type": "object",
  "required": ["event_id", "event_type", "timestamp", "data"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier"
    },
    "event_type": {
      "type": "string",
      "const": "OrderCreated"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of event creation"
    },
    "data": {
      "type": "object",
      "required": ["order_id", "customer_id", "currency", "amount", "items"],
      "properties": {
        "order_id": {
          "type": "string",
          "format": "uuid"
        },
        "customer_id": {
          "type": "string"
        },
        "currency": {
          "type": "string",
          "enum": ["USD", "EUR", "GBP", "JPY", "KRW", "CHF", "CAD", "AUD", "CNY", "INR"],
          "description": "ISO 4217 currency code"
        },
        "amount": {
          "type": "integer",
          "minimum": 1,
          "description": "Total amount in smallest currency unit (cents for USD, yen for JPY)"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["product_id", "name", "quantity", "unit_price"],
            "properties": {
              "product_id": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "integer", "minimum": 1 },
              "unit_price": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
