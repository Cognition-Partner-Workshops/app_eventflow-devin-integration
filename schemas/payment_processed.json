{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaymentProcessed Event",
  "description": "Event representing the result of payment processing by the Payment Service",
  "type": "object",
  "required": ["event_id", "event_type", "timestamp", "data"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "enum": ["PaymentCompleted", "PaymentFailed"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": ["payment_id", "order_id", "customer_id", "currency", "amount_minor", "amount_display", "status"],
      "properties": {
        "payment_id": {
          "type": "string",
          "format": "uuid"
        },
        "order_id": {
          "type": "string",
          "format": "uuid"
        },
        "customer_id": {
          "type": "string"
        },
        "currency": {
          "type": "string",
          "description": "ISO 4217 currency code"
        },
        "amount_minor": {
          "type": "integer",
          "description": "Amount in smallest currency unit"
        },
        "amount_display": {
          "type": "number",
          "description": "Amount in display format (e.g., dollars, euros, yen)"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "failed"]
        },
        "error_message": {
          "type": ["string", "null"],
          "description": "Error message if payment failed"
        }
      }
    }
  }
}
